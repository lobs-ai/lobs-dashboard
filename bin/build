#!/bin/bash
# Build script for lobs-dashboard.
# Embeds the current commit hash, builds, and saves the built-from hash
# to a known file on disk so the running app can detect when a rebuild is needed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
HASH_FILE="$HOME/.lobs/dashboard-build-commit"

cd "$REPO_DIR"

# 1. Generate build info (embeds commit in source for compile-time fallback)
bash "$SCRIPT_DIR/generate-build-info"

# 2. Build
echo "[build] Building lobs-dashboard…"
swift build

# 3. Save the built-from commit hash to disk for runtime detection
COMMIT=$(git rev-parse HEAD)
mkdir -p "$(dirname "$HASH_FILE")"
echo "$COMMIT" >"$HASH_FILE"
echo "[build] Saved build hash to $HASH_FILE: $(echo "$COMMIT" | head -c 7)"

echo "[build] Done. Run with: swift run"
